POSTGRES_PASSWORD=local-postgres-password
BENCH_PASSWORD=bench-password
BENCH_BACKEND_PASSWORD=bench-backend-password
METRICS_PASSWORD=metrics-password
PGBOUNCER_ADMIN_PASSWORD=pgbouncer-admin-password
LOCAL_DATASET_ROWS=100000
PGBOUNCER_PROCESSES=4
PGBOUNCER_TOPOLOGY=shared
TOTAL_POOL_BUDGET=128
POSTGRES_SSL=off
CLIENT_TLS_SSLMODE=disable
SERVER_TLS_SSLMODE=disable
PGBOUNCER_PEERING=1
AWS_PROFILE=your-aws-cli-profile
SSH_PRIVATE_KEY=/absolute/path/to/ec2-key.pem
